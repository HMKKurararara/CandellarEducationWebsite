# Sanity (create a project at sanity.io, then invite staff in Sanity Manage)
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2025-01-01
SANITY_API_WRITE_TOKEN=

# Parent enquiry notification (Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=
ADMISSIONS_EMAIL=

# Optional Cloudflare Turnstile spam protection (both values are required together)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Optional automatic Facebook Page feed
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_ACCESS_TOKEN=
# Copy the current vXX.X version shown by Meta's Graph API Explorer.
FACEBOOK_GRAPH_API_VERSION=v20.0

# Deployment and analytics
NEXT_PUBLIC_SITE_URL=
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
GOOGLE_SITE_VERIFICATION=
